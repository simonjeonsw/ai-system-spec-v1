{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "LearningGateOutput",
  "type": "object",
  "required": [
    "video_id",
    "decision",
    "action",
    "policy",
    "window_size",
    "evaluated_outcomes",
    "signals",
    "schema_version"
  ],
  "properties": {
    "video_id": { "type": "string" },
    "decision": { "type": "string" },
    "action": { "type": "string" },
    "policy": {
      "type": "object",
      "required": ["ctr_baseline", "avd_baseline", "rework_ctr_floor", "rework_avd_floor", "min_consecutive"],
      "properties": {
        "ctr_baseline": { "type": "number" },
        "avd_baseline": { "type": "number" },
        "rework_ctr_floor": { "type": "number" },
        "rework_avd_floor": { "type": "number" },
        "min_consecutive": { "type": "integer" }
      }
    },
    "window_size": { "type": "integer" },
    "evaluated_outcomes": { "type": "integer" },
    "signals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["created_at_utc", "ctr", "avd", "meets_publish", "meets_rework"],
        "properties": {
          "created_at_utc": { "type": ["string", "null"] },
          "ctr": { "type": ["number", "null"] },
          "avd": { "type": ["number", "null"] },
          "meets_publish": { "type": "boolean" },
          "meets_rework": { "type": "boolean" }
        }
      }
    },
    "schema_version": { "type": "string" }
  }
}
