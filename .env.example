# Copy to .env and fill with your own keys. Do not commit .env.

# Google API Keys
YOUTUBE_API_KEY=
GEMINI_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_ANON_KEY=

# Pipeline runtime
PIPELINE_PROFILE=core
